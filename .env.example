# Copy this file to .env and adjust values before running docker-compose.
# These are consumed by docker-compose.yml and passed into the backend container.

# JWT signing secret — MUST be changed for any real deployment.
SECRET_KEY=change-this-secret-key-in-production

# Minutes before a login token expires.
ACCESS_TOKEN_EXPIRE_MINUTES=60

# Comma-separated list of origins allowed to call the API.
CORS_ORIGINS=http://localhost:5173,http://localhost:8080

# Seed accounts created automatically on first startup.
# Change these immediately after first login in any real deployment.
DEFAULT_STUDENT_USER_ID=student
DEFAULT_STUDENT_PASSWORD=student123
DEFAULT_ADMIN_USER_ID=admin
DEFAULT_ADMIN_PASSWORD=admin123
