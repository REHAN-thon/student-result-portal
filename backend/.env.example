# Copy to backend/.env for local (non-Docker) development if you use a tool
# like python-dotenv, or export these variables in your shell before running
# uvicorn. All are optional — sensible defaults are used otherwise.

SECRET_KEY=change-this-secret-key-in-production
ACCESS_TOKEN_EXPIRE_MINUTES=60

DATABASE_URL=sqlite:///./app.db
UPLOAD_DIR=./uploads/results
MAX_UPLOAD_SIZE_MB=10

CORS_ORIGINS=http://localhost:5173,http://localhost:3000

DEFAULT_STUDENT_USER_ID=student
DEFAULT_STUDENT_PASSWORD=student123
DEFAULT_ADMIN_USER_ID=admin
DEFAULT_ADMIN_PASSWORD=admin123
